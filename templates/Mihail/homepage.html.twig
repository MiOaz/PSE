{% extends 'base.html.twig' %}

{% block title %}Pagini statice{% endblock %}

{% block stylesheets %}
<style>
    body {
        font-family: Arial, sans-serif;
        background: #f9f9f9;
        margin: 40px;
    }
    h1 {
        text-align: center;
        color: #333;
    }
    .pages-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 25px;
        margin-top: 40px;
    }
    .page-box {
        background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
        color: white;
        padding: 25px 40px;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 6px 12px rgba(254, 180, 123, 0.4);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        min-width: 160px;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .page-box:hover {
        transform: translateY(-6px);
        box-shadow: 0 14px 22px rgba(254, 180, 123, 0.7);
        background: linear-gradient(135deg, #feb47b 0%, #ff7e5f 100%);
    }
</style>
{% endblock %}

{% block body %}
    <h1>Pagini statice</h1>
    <div class="pages-container">
        {% for page in pages %}
            <a href="{{ path(page.route) }}" class="page-box">{{ page.name }}</a>
        {% else %}
            <p>Nu există pagini disponibile.</p>
        {% endfor %}
    </div>
{% endblock %}
