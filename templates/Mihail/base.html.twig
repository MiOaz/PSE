<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Pagina principală{% endblock %}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 30px;
            background-color: #f0f0f0;
        }
        .menu {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        .menu-box {
            background-color: white;
            border: 1px solid #ccc;
            padding: 20px;
            text-align: center;
            border-radius: 8px;
            width: 200px;
            text-decoration: none;
            color: black;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            transition: 0.3s;
        }
        .menu-box:hover {
            background-color: #e6f0ff;
        }
    </style>
</head>
<body>
    {% block body %}{% endblock %}
</body>
</html>
